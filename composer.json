{
  "name": "redaelfillali/laravel-backup",
  "description": "Laravel Backup solution for shared hosting",
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "google/apiclient": "^2.19",
    "league/flysystem": "^3.32"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0",
    "phpunit/phpunit": "^10.0|^11.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "Redaelfillali\\LaravelBackup\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Redaelfillali\\LaravelBackup\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Reda EL Fillali",
      "email": "reda.elfillali@gmail.com"
    }
  ],
  "license": "MIT",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "extra": {
    "laravel": {
      "providers": [
        "Redaelfillali\\LaravelBackup\\BackupServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
